# Etherscan API key — used to fetch verified Solidity source code for a given contract address.
# Obtain a free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Basescan API key — required when auditing Base contracts.
# Obtain a key at https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here

# Polygonscan API key — required when auditing Polygon contracts.
# Obtain a key at https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Kavascan API key — required when auditing Kava contracts.
# Obtain a key at https://kavascan.com/myapikey
KAVASCAN_API_KEY=your_kavascan_api_key_here
